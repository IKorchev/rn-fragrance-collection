# Copy this file to .env and fill in real values. Expo inlines EXPO_PUBLIC_*
# vars at build time (see https://docs.expo.dev/guides/environment-variables/).
# These are public-embedded values, not secrets — do not put server-only
# secrets here.

# Supabase dashboard -> Settings -> API (same project as fragrance-db)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
# (same clients as before; now registered with Supabase Auth's Google provider)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional: Sentry crash reporting (sentry.io -> project -> Client Keys).
# Leave empty to disable Sentry entirely.
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat dashboard -> Project settings -> API keys (public SDK keys, safe
# to embed like the Supabase anon key). Leave empty to disable Pro-tier
# purchases entirely (src/lib/purchases.ts no-ops if unset).
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=