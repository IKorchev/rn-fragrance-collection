# Copy this file to .env and fill in real values. Expo inlines EXPO_PUBLIC_*
# vars at build time (see https://docs.expo.dev/guides/environment-variables/).
# These are public-embedded values, not secrets — do not put server-only
# secrets here.

# Supabase dashboard -> Settings -> API (same project as fragrance-db)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
# (same clients as before; now registered with Supabase Auth's Google provider)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=